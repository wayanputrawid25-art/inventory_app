# Environment Variables Template
# Copy file ini ke .env dan sesuaikan dengan lingkungan Anda

# ===== FLASK CONFIGURATION =====
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# ===== DATABASE =====
# Neon/PostgreSQL connection string. Set this in GitHub Secrets as DATABASE_URL.
# Example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require
DATABASE_URL=

# Legacy MySQL settings are used only when DATABASE_URL is empty.
DB_HOST=localhost
DB_USER=app_user
DB_PASSWORD=secure_password_here
DB_NAME=cv_epic_warehouse_mysql
DB_PORT=3306

# ===== API =====
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=True

# ===== CORS =====
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:5000

# ===== JWT =====
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES=86400  # 24 hours in seconds
JWT_REFRESH_TOKEN_EXPIRES=2592000  # 30 days in seconds

# ===== FILE UPLOAD =====
MAX_CONTENT_LENGTH=52428800  # 50MB in bytes
UPLOAD_FOLDER=./static/uploads
BARCODE_FOLDER=./static/barcodes
REPORT_FOLDER=./static/reports

# ===== BARCODE SETTINGS =====
BARCODE_FORMAT=CODE128
QR_CODE_ENABLED=True
QR_CODE_VERSION=1

# ===== LOGGING =====
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=10

# ===== FEATURES =====
ENABLE_NOTIFICATION=True
ENABLE_AUDIT_LOG=True
ENABLE_EXPORT_EXCEL=True
ENABLE_EXPORT_PDF=True

# ===== NOTIFICATION SETTINGS =====
NOTIFICATION_EMAIL_ENABLED=False
NOTIFICATION_SLACK_ENABLED=False

# ===== SECURITY =====
BCRYPT_LOG_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_TIMEOUT=300  # 5 minutes in seconds

# ===== PAGINATION =====
ITEMS_PER_PAGE=20
MAX_ITEMS_PER_PAGE=100

# ===== SENTRY (Error tracking) =====
SENTRY_DSN=

# ===== REDIS (Optional, for caching) =====
REDIS_URL=redis://localhost:6379/0

# ===== TIMEZONE =====
TIMEZONE=Asia/Jakarta

# ===== VERSION =====
APP_VERSION=1.0.0
API_VERSION=v1
